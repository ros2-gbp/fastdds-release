From: Scott K Logan <logans@cottsay.net>
Date: Wed, 20 Jan 2021 12:08:26 -0800
Subject: [PATCH] Set CMake flags for Fast-DDS

Co-authored-by: Shane Loretz <shane.loretz@gmail.com>
---
 rpm/ros-lyrical-fastdds.spec | 3 +++
 1 file changed, 3 insertions(+)

diff --git a/rpm/ros-lyrical-fastdds.spec b/rpm/ros-lyrical-fastdds.spec
index 825445335e69..3387a0630695 100644
--- a/rpm/ros-lyrical-fastdds.spec
+++ b/rpm/ros-lyrical-fastdds.spec
@@ -81,6 +81,9 @@ giving the user full access to the protocol internals.
 %if !0%{?with_tests}
     -DBUILD_TESTING=OFF \
 %endif
+    -DINSTALL_EXAMPLES=OFF \
+    -DSECURITY=ON \
+    -DAPPEND_PROJECT_NAME_TO_INCLUDEDIR=ON \
 
 %cmake3_build
 
